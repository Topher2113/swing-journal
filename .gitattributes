# Normalize all text files to LF in the repo; editors can use whatever they like locally
* text=auto eol=lf

# Explicit binary files — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
*.zip  binary
*.apk  binary
